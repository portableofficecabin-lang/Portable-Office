# ═══════════════════════════════════════════════════════════════════════════════════════
#  Environment variables — copy to .env / .env.local and fill in. NEVER commit real keys.
# ═══════════════════════════════════════════════════════════════════════════════════════
#
#   .env        → non-secret config. NEXT_PUBLIC_* values are inlined into the browser
#                 bundle at BUILD time, so they must ALSO be set as build-time env vars on
#                 the host (DigitalOcean App Platform) or the deployed bundle keeps
#                 whatever was baked into the last build.
#   .env.local  → server-only SECRETS. Gitignored. Must stay uncommitted.
#
# ── Supabase ───────────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
# The client-safe publishable key (sb_publishable_...). Never the secret key.
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_xxxxxxxxxxxxxxxxxxxx
NEXT_PUBLIC_SITE_URL=https://portableofficecabin.com

# SERVER-ONLY. Bypasses Row Level Security — treat it like a database root password.
# Put this in .env.local (and in the host's *runtime* secrets), never in .env.
# Required by /api/razorpay/order and /api/razorpay/verify: RLS deliberately gives users
# NO UPDATE on `orders`, so only the server (holding this key) can mark an order paid.
SUPABASE_SERVICE_ROLE_KEY=sb_secret_xxxxxxxxxxxxxxxxxxxx

# ── Razorpay ───────────────────────────────────────────────────────────────────────────
# Get these from the Razorpay Dashboard → Settings → API Keys.
# Use rzp_test_* keys until the flow is verified, then swap to rzp_live_*.
#
# SERVER-ONLY (put both in .env.local / host runtime secrets):
#   RAZORPAY_KEY_ID     — the key id. Public-safe in itself, but read on the server and
#                         handed to the browser by /api/razorpay/order, so the checkout
#                         cannot drift from the key that actually created the order.
#   RAZORPAY_KEY_SECRET — THE SECRET. Signs and verifies payments. If this leaks, anyone
#                         can forge a "payment verified" signature. Never expose it, never
#                         prefix it with NEXT_PUBLIC_, never send it to the browser.
#
# Both API routes fail with an explicit 500 if either is missing — they will not silently
# pretend to take a payment.
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxxx
RAZORPAY_KEY_SECRET=xxxxxxxxxxxxxxxxxxxxxxxx

# OPTIONAL. The current checkout does NOT need this: it uses the keyId returned at runtime
# by /api/razorpay/order (which avoids the "NEXT_PUBLIC_ was baked into an old build"
# class of deploy bug entirely). Set it only if a client component ever needs the key id
# directly — and if you do, it MUST be identical to RAZORPAY_KEY_ID above.
# NEXT_PUBLIC_RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxxx
